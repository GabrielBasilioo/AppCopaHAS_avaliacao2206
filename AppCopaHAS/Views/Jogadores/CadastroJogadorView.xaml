<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCopaHAS.Views.Jogadores.CadastroJogadorView"
             Title="CadastroJogadorView">
    <ScrollView>
        <VerticalStackLayout Spacing="3" Padding="15">
            <Picker Title="---Seleção---" SelectedItem="{Binding SelecaoSelecionada}"
          ItemsSource="{Binding Selecoes}"
          ItemDisplayBinding="{Binding Pais}"/>
      
      <Label Text="Nome do Jogador" />
      <Entry Text="{Binding Nome}" />
      
      <Label Text="Posição"/>
      <Entry Text="{Binding Posicao}"/>
      
      <Label Text="Número da Camisa"/>
      <Entry Text="{Binding Numerocamisa }"  
             Keyboard="Numeric" />
<Button Text="Salvar" Command="{Binding SalvarCommand}"></Button>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
